# ============================================================
# Fichier d'exemple de variables d'environnement
# Copiez ce fichier en .env et renseignez vos valeurs :
#   cp .env.example .env
# ============================================================

# ---------------------------------------------------------------------------
# JWT signing secret — CHANGEZ CETTE VALEUR EN PRODUCTION
# Générez une valeur forte avec :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ---------------------------------------------------------------------------
JWT_SECRET=please-change-me-to-a-long-random-string-xxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_documents

# ---------------------------------------------------------------------------
# LLM (la clé OpenAI est saisie dans l'onglet Paramètres, chiffrée par user)
# ---------------------------------------------------------------------------
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# ---------------------------------------------------------------------------
# Embeddings — multilingue 1024 dim (modèle par défaut du runtime)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ---------------------------------------------------------------------------
# Retrieval
# ---------------------------------------------------------------------------
RETRIEVAL_K=5
RETRIEVAL_K_DENSE=20
RETRIEVAL_K_SPARSE=20
RRF_K=60

# ---------------------------------------------------------------------------
# Backend URL (utilisé par le frontend Next.js en mode Docker)
# ---------------------------------------------------------------------------
BACKEND_URL=http://backend:8000
