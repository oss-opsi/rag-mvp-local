# ============================================================
# Fichier d'exemple de variables d'environnement
# Copiez ce fichier en .env et renseignez vos valeurs
# ============================================================

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_documents

# LLM (la clé OpenAI est saisie dans l'interface Streamlit, pas ici)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
RETRIEVAL_K=5
RETRIEVAL_K_DENSE=20
RETRIEVAL_K_SPARSE=20
RRF_K=60

# Backend URL (utilisé par le frontend Streamlit en mode Docker)
BACKEND_URL=http://backend:8000
